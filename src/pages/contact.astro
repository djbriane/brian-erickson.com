---
import Page from "../layouts/Page.astro";
import resume from "../data/resume.json";

const links: Array<{ label: string; href: string; external: boolean }> = [
  { label: "Email", href: `mailto:${resume.basics.email}`, external: false },
];

if (resume.basics.linkedin) {
  links.push({ label: "LinkedIn", href: resume.basics.linkedin, external: true });
}

if (resume.basics.github) {
  links.push({ label: "GitHub", href: resume.basics.github, external: true });
}
---

<Page title="Contact" description="Contact links for Brian Erickson.">
  <header class="page-header">
    <p class="eyebrow">Contact</p>
    <h1>Get in touch</h1>
  </header>

  <ul class="contact-list">
    {links.map((link) => (
      <li>
        <a href={link.href} target={link.external ? "_blank" : undefined} rel={link.external ? "noreferrer" : undefined}>
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</Page>
