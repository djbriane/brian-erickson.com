---
import { existsSync } from "node:fs";
import ResumeSection from "../components/ResumeSection.astro";
import Page from "../layouts/Page.astro";
import resume from "../data/resume.json";

const hasResumePdf = existsSync(new URL("../../public/resume.pdf", import.meta.url));
const description = `${resume.basics.name}'s resume, experience, education, and skills.`;
---

<Page title="Resume" description={description}>
  <header class="page-header">
    <p class="eyebrow">Resume</p>
    <h1>{resume.basics.name}</h1>
    <p class="lede">{resume.basics.title}</p>
    {hasResumePdf && <p><a class="button-link" href="/resume.pdf">Download PDF</a></p>}
  </header>

  <div class="reading-width">
    <ResumeSection title="Summary">
      <p>{resume.basics.summary}</p>
    </ResumeSection>

    <ResumeSection title="Experience">
      <div class="timeline">
        {resume.experience.map((item) => (
          <article class="timeline-item">
            <p class="eyebrow">{item.start} - {item.end}</p>
            <h3>{item.title}</h3>
            <p class="muted">{item.company}</p>
            <p>{item.description}</p>
            <ul>
              {item.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </ResumeSection>

    <ResumeSection title="Education">
      <div class="stack">
        {resume.education.map((item) => (
          <article>
            <h3>{item.institution}</h3>
            <p>{item.degree}{item.year ? `, ${item.year}` : ""}</p>
          </article>
        ))}
      </div>
    </ResumeSection>

    <ResumeSection title="Skills">
      <div class="skill-grid">
        {Object.entries(resume.skills).map(([group, skills]) => (
          <section>
            <h3>{group}</h3>
            <ul>
              {skills.map((skill) => <li>{skill}</li>)}
            </ul>
          </section>
        ))}
      </div>
    </ResumeSection>
  </div>
</Page>

