---
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";
import PostListItem from "../components/PostListItem.astro";
import Page from "../layouts/Page.astro";
import { isPublishedPost, sortByDateDesc } from "../lib/content";
import resume from "../data/resume.json";

const posts = sortByDateDesc((await getCollection("blog")).filter(isPublishedPost)).slice(0, 3);
const featuredProjects = (await getCollection("projects")).filter((project) => project.data.featured);
---

<Page>
  <section class="hero">
    <p class="eyebrow">Brian Erickson</p>
    <h1>{resume.basics.title}</h1>
    <p class="lede">{resume.basics.summary}</p>
  </section>

  <section class="section-band">
    <div class="section-heading">
      <p class="eyebrow">Featured Work</p>
      <h2>Product work with terrain under it</h2>
    </div>
    <div class="project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section-band">
    <div class="section-heading">
      <p class="eyebrow">From the Archive</p>
      <h2>Writing</h2>
    </div>
    {posts.length > 0 ? (
      <div class="post-list">
        {posts.map((post) => <PostListItem post={post} />)}
      </div>
    ) : (
      <p class="muted">The Ghost archive will appear here after migration.</p>
    )}
  </section>
</Page>

