---
interface Props {
  title: string;
  summary: string;
  href: string;
  status?: string;
  focus?: string[];
  started?: string;
}
const { title, summary, href, status, focus = [], started } = Astro.props;
---
<article class="card">
  <div class="meta-row">
    {status && <span class="meta">Status · {status}</span>}
    {started && <span class="meta">Started · {started}</span>}
  </div>
  <h3><a class="arrow" href={href}>{title}</a></h3>
  <p class="summary">{summary}</p>
  {focus.length > 0 && (
    <div>
      {focus.map((f) => <span class="tag">{f}</span>)}
    </div>
  )}
</article>
