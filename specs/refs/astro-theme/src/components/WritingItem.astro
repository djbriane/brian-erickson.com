---
interface Props {
  title: string;
  href: string;
  date: Date;
  summary: string;
  tags?: string[];
}
const { title, href, date, summary, tags = [] } = Astro.props;
const formatted = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<article class="card">
  <div class="meta-row">
    <span class="meta">{formatted}</span>
    {tags.map((t) => <span class="tag">{t}</span>)}
  </div>
  <h3><a class="arrow" href={href}>{title}</a></h3>
  <p class="summary">{summary}</p>
</article>
